ANTHROPIC_API_KEY=sk-ant-...

# ── Pipeline stage control ─────────────────────────────────────────────────
# Stop the pipeline early and print output at that stage. Leave blank to run everything.
#   ingest  → print ingested articles and exit (no LLM calls)
#   script  → print generated script JSON and exit (no audio/video)
#   voice   → generate voice only, skip video composition
PIPELINE_STOP_AFTER=

# Set to true to skip ElevenLabs and reuse output/voice_dev.mp3 (saves credits while testing)
DEV_SKIP_TTS=false
PEXELS_API_KEY=your_pexels_api_key_here
ELEVENLABS_API_KEY=...
# Default voice: Rachel (neutral tone). Override with any ElevenLabs voice ID.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TRIGGER_SECRET_KEY=tr_pat_...
OUTPUT_DIR=./output
