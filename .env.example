ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cjVigY5qzO86Huf0OWal
TRIGGER_SECRET_KEY=
OUTPUT_DIR=./output
PEXELS_API_KEY=
DEV_SKIP_TTS=false
IS_BREAKING_NEWS=false
HUMAN_IN_THE_LOOP=true

# ── Dedup cache ────────────────────────────────────────────────────────────
# Set to true to wipe the seen-signals cache before running (use after test runs
# so the same signals are available for the production run).
CLEAR_DEDUP_CACHE=true

# ── Pipeline stage control ─────────────────────────────────────────────────
# Stop the pipeline early and print output at that stage. Leave blank to run everything.
#   ingest  → print ingested articles and exit (no LLM calls)
#   script  → print generated script JSON and exit (no audio/video)
#   voice   → generate voice only, skip video composition
PIPELINE_STOP_AFTER=