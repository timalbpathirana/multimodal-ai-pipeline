ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cjVigY5qzO86Huf0OWal
TRIGGER_SECRET_KEY=
OUTPUT_DIR=./output
PEXELS_API_KEY=
DEV_SKIP_TTS=false
IS_BREAKING_NEWS=false
HUMAN_IN_THE_LOOP=true

# ── Weekly ingest mode ─────────────────────────────────────────────────────
# Set to true to run the weekly ingest instead of generating a video.
# Ingest fetches 7 days of RSS, YouTube, and web data, generates 28 story ideas,
# archives last week's stories in Airtable, and saves the new stories.
# You will be prompted for confirmation before it runs.
# Number of videos to generate per pipeline run (default: 1)
NUMBER_OF_VIDEOS=2

RUN_INGEST=false

# Days of history to fetch during ingest (default: 7)
INGEST_LOOKBACK_DAYS=7

# Number of stories to generate per ingest run (default: 28 = 4 videos/day × 7 days)
STORIES_PER_WEEK=28

# ── Serper web search ──────────────────────────────────────────────────────
# Used during weekly ingest to supplement RSS and YouTube with Google News results.
# Get a free API key at https://serper.dev
SERPER_API_KEY=

# ── Airtable ───────────────────────────────────────────────────────────────
# Stories are stored in Airtable. Create a base with the schema in AIRTABLE_SETUP.md.
# Personal access token: https://airtable.com/create/tokens
AIRTABLE_API_KEY=
# Base ID from the Airtable URL (starts with "app")
AIRTABLE_BASE_ID=
# Table name (default: Stories)
AIRTABLE_STORIES_TABLE=Stories

# ── Web server (Phase B+) ─────────────────────────────────────────────────
# Required when running the hosted web app (node web/server/index.js)
DATABASE_URL=postgresql://user:pass@localhost:5432/property_agent
SESSION_SECRET=change-me-to-32-random-chars
PORT=3000
NODE_ENV=development
OUTPUT_BASE_DIR=./output

# Admin account — seeded once on first startup (node web/server/scripts/seed.js)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Pipeline stage control ─────────────────────────────────────────────────
# Stop the pipeline early and print output at that stage. Leave blank to run everything.
#   ingest  → (breaking news mode only) print ingested articles and exit
#   script  → print generated script and exit (no audio/video)
#   voice   → generate voice only, skip video composition
PIPELINE_STOP_AFTER=